{
  "name": "contentpicker",
  "version": "1.0.0",
  "description": "Chrome 扩展：采集网页内容并生成 Markdown",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "node --loader ts-node/esm scripts/build.ts",
    "build:popup": "vite build",
    "lint": "eslint --ext .ts,.tsx src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "classnames": "^2.5.1",
    "dompurify": "^3.4.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "postcss": "^8.5.14",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
